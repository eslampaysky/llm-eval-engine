# Environment variables & secrets — NEVER commit real keys
.env
.env.*
*.key
*.pem
*.secret
**/secrets/

# Python
__pycache__/
*.py[cod]
*.pyo
.Python

# Virtual environment
venv/
env/
.venv/

# Reports output
reports/*.json
reports/*.html

# SQLite / local runtime state
usage.db
*.db
*.sqlite
*.sqlite3

# Local scratch data
.tmp-data/
artifacts/failure_patterns/

# IDE
.vscode/
.idea/

# Node
node_modules/

# Gemini file cache (free-tier rate-limit helper)
aibreaker_gemini_cache/

# Real user audit raw responses (large files)
artifacts/real_user_data/runs/**/*.json
# Keep summary files tracked
!artifacts/real_user_data/summary.csv
!artifacts/real_user_data/failure_patterns.json
!artifacts/real_user_data/README.md
